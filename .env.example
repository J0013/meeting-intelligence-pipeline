# ── Plantilla de variables de entorno ──
# Copia este archivo como .env y rellena tus valores reales.
# NUNCA subas el .env real al repositorio.

# ── PostgreSQL ──
POSTGRES_HOST=<TU_DB_HOST>
POSTGRES_PORT=5432
POSTGRES_DB=<TU_DB_NOMBRE>
POSTGRES_USER=<TU_DB_USUARIO>
POSTGRES_PASSWORD=<TU_DB_PASSWORD>

# ── Correo entrante (IMAP) — detección del resumen de reunión ──
IMAP_HOST=<TU_IMAP_HOST>
IMAP_PORT=993
IMAP_USER=<TU_CORREO>
IMAP_PASSWORD=<TU_IMAP_PASSWORD>

# ── Correo saliente (SMTP) — entrega del documento ──
SMTP_HOST=<TU_SMTP_HOST>
SMTP_PORT=587
SMTP_USER=<TU_CORREO>
SMTP_PASSWORD=<TU_SMTP_PASSWORD>

# ── n8n ──
N8N_HOST=<TU_DOMINIO>
N8N_ENCRYPTION_KEY=<TU_ENCRYPTION_KEY>
